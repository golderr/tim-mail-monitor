TIM_MAILBOX_DISPLAY_NAME=Tim Principal Mailbox
GRAPH_MAIL_FOLDERS=Inbox,SentItems
GRAPH_MESSAGE_PAGE_SIZE=50
GRAPH_TIMEOUT_SECONDS=30
SYNC_LOOKBACK_DAYS=14
SYNC_OVERLAP_MINUTES=5
SYNC_MAX_MESSAGES_PER_FOLDER=200
NON_CONSULTING_INTERNAL_EMAILS=tmc@theconcordgroup.com,ccr@theconcordgroup.com,rmg@theconcordgroup.com,mdr@theconcordgroup.com,aot@theconcordgroup.com,tjm@theconcordgroup.com,aes@theconcordgroup.com
